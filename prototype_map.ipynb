   "source": [
    "def encode_paper(paper):\n",
    "    abstract = paper[\"abstract\"]\n",
    "    if pd.isna(abstract):\n",
    "        return None  # Skip papers without abstracts\n",
    "    embedding = model.encode(abstract)\n",
    "    return embedding\n",
    "\n",
    "papers56[\"embedding\"] = papers56.apply(encode_paper, axis=1)\n"
   ]
  },
